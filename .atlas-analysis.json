  "keyFeatures": [
    "22+ accessible React components following WAI-ARIA patterns",
    "Full theming support via ThemeProvider and theme object customization",
    "RTL (right-to-left) layout support built in",
    "Light and dark color scheme support via ColorSchemeProvider",
    "TypeScript-first with comprehensive type definitions",
    "Container-View-Element architecture for separation of concerns",
    "Individual npm packages for tree-shakeable consumption",
    "styled-components based with CSS-in-JS theming"
  ],
  "publicApiSurface": [
    "Accordion, Accordion.Header, Accordion.Label, Accordion.Panel, Accordion.Section",
    "Button, Button.StartIcon, Button.EndIcon",
    "Field, Input, Textarea, Select, Checkbox, Radio, Toggle, Range, FileUpload, FileList",
    "Modal, Modal.Header, Modal.Body, Modal.Footer, Modal.FooterItem, Modal.Close",
    "Drawer, TooltipDialog",
    "ThemeProvider, ColorSchemeProvider, DEFAULT_THEME, useColorScheme",
    "Notification, Alert, Well",
    "Tooltip",
    "Table, Table.Head, Table.Body, Table.Row, Table.Cell, Table.SortableCell",
    "Tabs, Tabs.Tab, Tabs.Panel, Tabs.TabList",
    "Tag, Tag.Close",
    "Avatar, Avatar.Text, Avatar.Status",
    "Breadcrumb",
